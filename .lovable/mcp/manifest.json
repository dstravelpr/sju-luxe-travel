{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "sju-luxe-travel-mcp",
      "version": "0.1.0",
      "title": "SJU Luxe Travel"
    },
    "tools": [
      {
        "name": "list_blog_posts",
        "title": "List blog posts",
        "description": "Return the published SJU Luxe Travel blog posts with title, slug, language, topic, and full URL. Optional topic filter.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "topic": {
              "description": "Optional topic filter (e.g. wellness, cruises, honeymoon).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_destinations",
        "title": "List destinations",
        "description": "Return SJU Luxe Travel's featured luxury destinations with a short summary and canonical URL.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "description": "Optional single destination slug (maldives | portugal | mexico).",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_contact_info",
        "title": "Get contact info",
        "description": "Return SJU Luxe Travel contact details: advisor, phone, email, location, booking page, and social links.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "request_trip_quote",
        "title": "Request trip quote",
        "description": "Draft a luxury trip inquiry for SJU Luxe Travel. Returns a formatted inquiry summary and the contact URL the traveler should use to send it. Does not submit anything — the traveler must reach out via the contact page, email, or phone.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "traveler_name": {
              "type": "string",
              "minLength": 1,
              "description": "Traveler's full name."
            },
            "destination": {
              "type": "string",
              "minLength": 1,
              "description": "Requested destination or region."
            },
            "travel_dates": {
              "type": "string",
              "minLength": 1,
              "description": "Approximate travel dates or window."
            },
            "party_size": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991,
              "description": "Number of travelers."
            },
            "budget_usd": {
              "description": "Total budget in USD (optional).",
              "type": "number",
              "exclusiveMinimum": 0
            },
            "notes": {
              "description": "Style, occasion, preferences, or must-haves.",
              "type": "string"
            }
          },
          "required": [
            "traveler_name",
            "destination",
            "travel_dates",
            "party_size"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
